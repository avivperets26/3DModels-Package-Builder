# Repository-local tools and generated state
# These roots are intentional project-owned locations beneath C:\Dev\PackageBuilder.
/tools/
/downloads/
/logs/
/runtime-data/
/artifacts/

# .NET build output, test results, and local caches
**/[Bb]in/
**/[Oo]bj/
**/TestResults/
**/BenchmarkDotNet.Artifacts/
*.binlog
*.trx
**/.coverage
**/.coverage.*
**/coverage.cobertura.xml
**/coverage.opencover.xml
**/coverage.json

# Visual Studio and JetBrains per-user state
**/.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings.user
*.iws
**/.idea/**/workspace.xml
**/.idea/**/tasks.xml
**/.idea/**/usage.statistics.xml
**/.idea/**/dataSources.local.xml
**/.idea/**/dataSources/
**/.idea/**/shelf/
**/.idea/**/httpRequests/
**/_ReSharper.Caches/
**/.ReSharper/

# Visual Studio Code machine-local state
# Do not ignore .vscode itself: shared settings, tasks, launch files, and extensions stay trackable.
**/.vscode/*.local.json
**/.vscode/.history/
**/.vscode/.cache/
**/.vscode/ipch/
**/.vscode/.browse.VC.db*
**/.vscode/compileCommands*.json
**/.vscode/compile_commands.json

# PowerShell, Python, and local test-tool caches
**/__pycache__/
*.py[cod]
*$py.class
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/.pytype/
**/.hypothesis/
**/.tox/
**/.nox/
**/.venv/
**/venv/
**/.eggs/
**/*.egg-info/
**/pip-wheel-metadata/
**/PesterResults*.xml
**/PowerShell_transcript.*.txt
**/ModuleAnalysisCache

# Blender backup, recovery, cache, crash, and Python-generated state
*.blend[1-9]*
*.blend@
**/quit.blend
**/*_autosave.blend
**/blendcache_*/
**/.blender-cache/
**/blender.crash.txt

# Unity generated and machine-local state
# Assets, Packages, ProjectSettings, scenes, prefabs, materials, and package inputs remain trackable.
**/[Ll]ibrary/
**/[Tt]emp/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/
**/[Bb]uild/
**/[Bb]uilds/
**/.utmp/
**/.gradle/
**/[Mm]emoryCaptures/
**/[Rr]ecordings/
**/[Cc]rashes/
**/[Cc]rashReports/
**/[Ee]xportedObj/
*.opendb
*.VC.db
**/sysinfo.txt
/engine-templates/unity/**/*.csproj
/engine-templates/unity/**/*.sln

# Unreal generated binaries, caches, intermediates, saved state, and local dependency state
# Config, Content, Source, .uproject, .uasset, and .umap files remain trackable.
**/[Bb]inaries/
**/[Dd]erivedDataCache/
**/[Ii]ntermediate/
**/[Ss]aved/
**/.ue4dependencies/
/engine-templates/unreal/**/*.sln

